---
import type Project from "types/Project";
import type SEO from "types/SEO";

import BaseLayout from "@layouts/BaseLayout.astro";
import NavBar from "@components/NavBar.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ProjectGrid from "@components/ProjectGrid.astro";
import { compareProjectsByPeriod } from "../../utils/project-sort";

type MarkdownModule<T> = { frontmatter: T; url: string };

const SEO: SEO = {
  title: "Projects in software and social impact | Dan Ferg",
  description:
    "Explore Dan Ferg's projects across startups, social impact, community technology, leadership, and practical software.",
  imageUrl: "/images/og-default.png",
  openGraph: { type: "website" },
  canonicalUrl: "/projects",
  schemaType: "CollectionPage",
};

const projects = Object.values(
  import.meta.glob<MarkdownModule<Project>>("./*.md", { eager: true })
).sort(compareProjectsByPeriod);
---

<BaseLayout {...SEO}>
  <NavBar />
  <main id="main-content" class="site-container archive">
    <p class="breadcrumb"><a href="/">HOME</a> / PROJECTS</p>
    <SectionHeading
      as="h1"
      eyebrow="ARCHIVE_01 // PROJECTS"
      title="Useful things I’ve built."
      description={`${projects.length} experiments, products, and ventures. Some shipped, some taught me what to build next; all started with a real problem.`}
    />
    <ProjectGrid projects={projects} />
  </main>
</BaseLayout>

<style>
  .archive {
    padding-block: clamp(2.75rem, 5vw, 4.75rem);
  }

  .breadcrumb {
    margin: 0 0 clamp(2.5rem, 4vw, 4rem);
    color: var(--ink-muted);
    font-size: 0.64rem;
  }

  .breadcrumb a {
    color: var(--ink);
    text-underline-offset: 0.2em;
  }
</style>
