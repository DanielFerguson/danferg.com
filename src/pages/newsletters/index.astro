---
import type SEO from "types/SEO";
import { getCollection } from "astro:content";
import getReadingTime from "reading-time";

import BaseLayout from "@layouts/BaseLayout.astro";
import NavBar from "@components/NavBar.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ContentList from "@components/ContentList.astro";

const SEO: SEO = {
  title: "Newsletters on building projects and solving problems | Dan Ferg",
  description:
    "Read Dan Ferg's newsletters about startup progress, ideas, project updates, and lessons learned while building in public.",
  imageUrl: "/images/og-default.png",
  openGraph: { type: "website" },
  canonicalUrl: "/newsletters",
  schemaType: "CollectionPage",
  breadcrumbs: [
    { name: "Home", url: "/" },
    { name: "Newsletters", url: "/newsletters" },
  ],
};

const newsletters = (await getCollection("newsletters")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("en-AU", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  }).format(new Date(`${date}T00:00:00`));

const items = newsletters.map((newsletter) => ({
  title: newsletter.data.title,
  description: newsletter.data.description,
  href: newsletter.data.canonicalUrl,
  meta: formatDate(newsletter.data.date),
  detail: getReadingTime(newsletter.body || "").text,
}));
const itemListId = "https://danferg.com/newsletters#itemlist";
const itemListJsonLd = {
  "@type": "ItemList",
  "@id": itemListId,
  name: "Dan Ferg newsletters",
  numberOfItems: items.length,
  itemListOrder: "https://schema.org/ItemListOrderDescending",
  itemListElement: items.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.title,
    url: new URL(item.href, "https://danferg.com").toString(),
  })),
};
---

<BaseLayout {...SEO} mainEntityId={itemListId} jsonLd={itemListJsonLd}>
  <NavBar />
  <main id="main-content" class="site-container archive">
    <p class="breadcrumb"><a href="/">HOME</a> / NEWSLETTERS</p>
    <SectionHeading
      as="h1"
      eyebrow="ARCHIVE_03 // NEWSLETTERS"
      title="Dispatches from the workbench."
      description={`${newsletters.length} longer updates from the projects, ideas, and experiments I was building in public.`}
    />
    <ContentList items={items} orderedLabel="All newsletters" />
  </main>
</BaseLayout>

<style>
  .archive {
    padding-block: clamp(2.75rem, 5vw, 4.75rem);
  }

  .breadcrumb {
    margin: 0 0 clamp(2.5rem, 4vw, 4rem);
    color: var(--ink-muted);
    font-size: 0.64rem;
  }

  .breadcrumb a {
    color: var(--ink);
    text-underline-offset: 0.2em;
  }
</style>
