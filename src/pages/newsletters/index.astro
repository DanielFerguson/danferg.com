---
import type NewsletterType from "types/Newsletter";
import type SEO from "types/SEO";

import BaseLayout from "@layouts/BaseLayout.astro";
import NavBar from "@components/NavBar.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ContentList from "@components/ContentList.astro";

type MarkdownModule<T> = { frontmatter: T; url: string };

const SEO: SEO = {
  title: "Newsletters on building projects and solving problems | Dan Ferg",
  description:
    "Read Dan Ferg's newsletters about startup progress, ideas, project updates, and lessons learned while building in public.",
  imageUrl: "/assets/snow.jpg",
  openGraph: { type: "website" },
  canonicalUrl: "/newsletters",
  schemaType: "CollectionPage",
};

const newsletters = Object.values(
  import.meta.glob<MarkdownModule<NewsletterType>>("./*.mdx", { eager: true })
).sort(
  (a, b) =>
    new Date(b.frontmatter.date).getTime() -
    new Date(a.frontmatter.date).getTime()
);

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("en-AU", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  }).format(new Date(`${date}T00:00:00`));

const items = newsletters.map((newsletter) => ({
  title: newsletter.frontmatter.title,
  description: newsletter.frontmatter.description,
  href: newsletter.url,
  meta: formatDate(newsletter.frontmatter.date),
  detail: newsletter.frontmatter.minutesRead,
}));
---

<BaseLayout {...SEO}>
  <NavBar />
  <main class="site-container archive">
    <p class="breadcrumb"><a href="/">HOME</a> / NEWSLETTERS</p>
    <SectionHeading
      as="h1"
      eyebrow="ARCHIVE_03 // NEWSLETTERS"
      title="Dispatches from the workbench."
      description={`${newsletters.length} longer updates from the projects, ideas, and experiments I was building in public.`}
    />
    <ContentList items={items} orderedLabel="All newsletters" />
  </main>
</BaseLayout>

<style>
  .archive {
    padding-block: clamp(2.75rem, 5vw, 4.75rem);
  }

  .breadcrumb {
    margin: 0 0 clamp(2.5rem, 4vw, 4rem);
    color: var(--ink-muted);
    font-size: 0.64rem;
  }

  .breadcrumb a {
    color: var(--ink);
    text-underline-offset: 0.2em;
  }
</style>
