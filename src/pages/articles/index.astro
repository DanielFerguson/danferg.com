---
import type Article from "types/Article";
import type SEO from "types/SEO";

import BaseLayout from "@layouts/BaseLayout.astro";
import NavBar from "@components/NavBar.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ContentList from "@components/ContentList.astro";

type MarkdownModule<T> = { frontmatter: T; url: string };

const SEO: SEO = {
  title: "Articles on startups, software and social impact | Dan Ferg",
  description:
    "Read Dan Ferg's articles on entrepreneurship, software, startup experiments, burnout, and building useful things.",
  imageUrl: "/images/og-default.png",
  openGraph: { type: "website" },
  canonicalUrl: "/articles",
  schemaType: "CollectionPage",
};

const articles = Object.values(
  import.meta.glob<MarkdownModule<Article>>("./*.md", { eager: true })
).sort(
  (a, b) =>
    new Date(b.frontmatter.date).getTime() -
    new Date(a.frontmatter.date).getTime()
);

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("en-AU", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  }).format(new Date(`${date}T00:00:00`));

const items = articles.map((article) => ({
  title: article.frontmatter.title,
  description: article.frontmatter.description,
  href: article.url,
  meta: formatDate(article.frontmatter.date),
  detail: article.frontmatter.minutesRead,
}));
---

<BaseLayout {...SEO}>
  <NavBar />
  <main id="main-content" class="site-container archive">
    <p class="breadcrumb"><a href="/">HOME</a> / ARTICLES</p>
    <SectionHeading
      as="h1"
      eyebrow="ARCHIVE_02 // ARTICLES"
      title="Notes from making things."
      description={`${articles.length} essays on building, learning, burning out, and beginning again.`}
    />
    <ContentList items={items} orderedLabel="All articles" />
  </main>
</BaseLayout>

<style>
  .archive {
    padding-block: clamp(2.75rem, 5vw, 4.75rem);
  }

  .breadcrumb {
    margin: 0 0 clamp(2.5rem, 4vw, 4rem);
    color: var(--ink-muted);
    font-size: 0.64rem;
  }

  .breadcrumb a {
    color: var(--ink);
    text-underline-offset: 0.2em;
  }
</style>
