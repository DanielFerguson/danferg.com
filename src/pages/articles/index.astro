---
// Types
import type Article from "types/Article";
import type SEO from "types/SEO";

import dayjs from "dayjs";
import BaseLayout from "@layouts/BaseLayout.astro";
import NavBar from "@components/NavBar.astro";
import CardGrid from "@components/CardGrid.astro";

type MarkdownModule<T> = {
  frontmatter: T;
  url: string;
};

// Data
const SEO: SEO = {
  title: "Articles on startups, software and social impact | Dan Ferg",
  description:
    "Read Dan Ferg's articles on entrepreneurship, software, startup experiments, burnout, social impact, product building, and lessons from the journey.",
  imageUrl: "/assets/snow.jpg",
  openGraph: {
    type: "website",
  },
  canonicalUrl: "/articles",
  schemaType: "CollectionPage",
};

const articles = Object.values(
  import.meta.glob<MarkdownModule<Article>>("./*.md", { eager: true })
);
const sortedArticles = articles.sort(function (a, b) {
  return (
    new Date(b.frontmatter.date).getTime() -
    new Date(a.frontmatter.date).getTime()
  );
});
---

<BaseLayout {...SEO}>
  <div class="mx-auto max-w-7xl sm:px-12">
    <NavBar />
  </div>

  <!-- Featured Article -->
  <div class="bg-white pb-8 sm:pb-12">
    <div class="overflow-hidden pt-8 sm:pt-12 lg:relative lg:py-48">
      <div
        class="mx-auto px-12 sm:max-w-3xl sm:px-6 lg:grid lg:max-w-7xl lg:grid-cols-2 lg:gap-24 lg:px-12"
      >
        <a href={sortedArticles[0].url}>
          <div class="mt-20">
            <span
              class="rounded bg-indigo-50 px-2.5 py-1 text-sm font-semibold text-indigo-600"
              >What's new</span
            >
            <div class="mt-6 sm:max-w-xl">
              <h1
                class="text-4xl font-bold tracking-tight text-gray-900 hover:text-indigo-600 sm:text-5xl"
              >
                {sortedArticles[0].frontmatter.title}
              </h1>
              <p class="mt-6 text-xl leading-8 tracking-tight text-gray-500">
                {sortedArticles[0].frontmatter.description}
              </p>
            </div>
          </div>
        </a>
      </div>

      <div class="sm:mx-auto sm:max-w-3xl sm:px-6">
        <div
          class="py-12 sm:relative sm:mt-12 sm:py-16 lg:absolute lg:inset-y-0 lg:right-0 lg:w-1/2"
        >
          <div class="hidden sm:block">
            <div
              class="absolute inset-y-0 left-1/2 w-screen rounded-l-3xl bg-gray-50 lg:left-80 lg:right-0 lg:w-full"
            >
            </div>
            <svg
              class="absolute top-8 right-1/2 -mr-3 lg:left-0 lg:m-0"
              width="404"
              height="392"
              fill="none"
              viewBox="0 0 404 392"
            >
              <defs>
                <pattern
                  id="837c3e70-6c3a-44e6-8854-cc48c737b659"
                  x="0"
                  y="0"
                  width="20"
                  height="20"
                  patternUnits="userSpaceOnUse"
                >
                  <rect
                    x="0"
                    y="0"
                    width="4"
                    height="4"
                    class="text-gray-200"
                    fill="currentColor"></rect>
                </pattern>
              </defs>
              <rect
                width="404"
                height="392"
                fill="url(#837c3e70-6c3a-44e6-8854-cc48c737b659)"></rect>
            </svg>
          </div>
          <div
            class="relative -mr-40 pl-12 sm:mx-auto sm:max-w-3xl sm:px-0 lg:h-full lg:max-w-none lg:pl-12"
          >
            <img
              class="w-full rounded-md shadow-xl ring-1 ring-black ring-opacity-5 lg:h-full lg:w-auto lg:max-w-none"
              src={sortedArticles[0].frontmatter.imageUrl}
              width={1280}
              height={720}
              loading="eager"
              decoding="async"
              alt={`${sortedArticles[0].frontmatter.title} article cover image`}
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Articles -->
  <CardGrid>
    {
      sortedArticles.slice(1).map((article) => (
        <div class="flex flex-col overflow-hidden rounded-lg shadow-lg">
          <div class="flex-shrink-0">
            <img
              class="h-48 w-full object-cover"
              src={article.frontmatter.imageUrl}
              width={640}
              height={360}
              loading="lazy"
              decoding="async"
              alt={`${article.frontmatter.title} article cover image`}
            />
          </div>
          <div class="flex flex-1 flex-col justify-between bg-white p-8">
            <div class="flex-1">
              <a href={article.url} class="block">
                <p class="text-xl font-semibold text-gray-900">
                  {article.frontmatter.title}
                </p>
                <p class="mt-3 text-base text-gray-500">
                  {article.frontmatter.description}
                </p>
              </a>
            </div>
            <div class="mt-6">
              <div class="flex space-x-1 text-sm text-gray-500">
                <time datetime={article.frontmatter.date}>
                  {dayjs(article.frontmatter.date).format("MMM D, YYYY")}
                </time>
                <span aria-hidden="true">&middot;</span>
                <span>{article.frontmatter.minutesRead}</span>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </CardGrid>
</BaseLayout>
