---
import type SEO from "types/SEO";
import { getCollection } from "astro:content";
import getReadingTime from "reading-time";

import BaseLayout from "@layouts/BaseLayout.astro";
import NavBar from "@components/NavBar.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ContentList from "@components/ContentList.astro";
import { editorialUpdates } from "../../data/editorial-updates";

const SEO: SEO = {
  title: "Articles on startups, software and social impact | Dan Ferg",
  description:
    "Read Dan Ferg's articles on entrepreneurship, software, startup experiments, burnout, and building useful things.",
  imageUrl: "/images/og-default.png",
  openGraph: { type: "website" },
  canonicalUrl: "/articles",
  schemaType: "CollectionPage",
  breadcrumbs: [
    { name: "Home", url: "/" },
    { name: "Articles", url: "/articles" },
  ],
};

const articles = (await getCollection("articles")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const articleDrafts = import.meta.env.DEV
  ? await getCollection("articleDrafts")
  : [];

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("en-AU", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  }).format(new Date(`${date}T00:00:00`));

const items = [
  ...articleDrafts.map((article) => ({
    title: article.data.title,
    description: article.data.description,
    href: article.data.canonicalUrl,
    date: article.data.date,
    meta: `DRAFT // ${formatDate(article.data.date)}`,
    detail: `${getReadingTime(article.body || "").text} · LOCAL ONLY`,
  })),
  ...articles.map((article) => ({
    title: article.data.title,
    description: article.data.description,
    href: article.data.canonicalUrl,
    date: article.data.date,
    meta: formatDate(article.data.date),
    detail: getReadingTime(article.body || "").text,
  })),
  ...editorialUpdates.map((update) => ({
    title: update.title,
    description: update.description,
    href: update.canonicalUrl,
    date: update.date,
    meta: formatDate(update.date),
    detail: update.category,
  })),
]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .map(({ date: _date, ...item }) => item);
const itemListId = "https://danferg.com/articles#itemlist";
const publishedItemCount = items.length - articleDrafts.length;
const itemListJsonLd = {
  "@type": "ItemList",
  "@id": itemListId,
  name: "Dan Ferg articles and research notes",
  numberOfItems: items.length,
  itemListOrder: "https://schema.org/ItemListOrderDescending",
  itemListElement: items.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.title,
    url: new URL(item.href, "https://danferg.com").toString(),
  })),
};
---

<BaseLayout {...SEO} mainEntityId={itemListId} jsonLd={itemListJsonLd}>
  <NavBar />
  <main id="main-content" class="site-container archive">
    <p class="breadcrumb"><a href="/">HOME</a> / ARTICLES</p>
    <SectionHeading
      as="h1"
      eyebrow="ARCHIVE_02 // ARTICLES"
      title="Notes from making things."
      description={`${publishedItemCount} essays and research notes on building, learning, burning out, and beginning again.${articleDrafts.length ? ` ${articleDrafts.length} local draft${articleDrafts.length === 1 ? "" : "s"} shown in development only.` : ""}`}
    />
    <ContentList items={items} orderedLabel="All articles" />
  </main>
</BaseLayout>

<style>
  .archive {
    padding-block: clamp(2.75rem, 5vw, 4.75rem);
  }

  .breadcrumb {
    margin: 0 0 clamp(2.5rem, 4vw, 4rem);
    color: var(--ink-muted);
    font-size: 0.64rem;
  }

  .breadcrumb a {
    color: var(--ink);
    text-underline-offset: 0.2em;
  }
</style>
