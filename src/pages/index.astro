---
import type SEO from "types/SEO";
import { getCollection } from "astro:content";
import getReadingTime from "reading-time";

import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import ContentList from "../components/ContentList.astro";
import HeroPortrait from "../components/HeroPortrait.astro";
import WorkHistory from "../components/WorkHistory.astro";
// import FavouriteStack from "../components/FavouriteStack.astro";
import ImpactStats from "../components/ImpactStats.astro";
import { compareProjectsByPeriod } from "../utils/project-sort";
import { editorialUpdates } from "../data/editorial-updates";

const SEO: SEO = {
  title: "Product consultant, advisor and software builder | Dan Ferg",
  headline: "Technology for problems that actually matter.",
  description:
    "Dan Ferg builds and advises on practical products, traction, go-to-market strategy, and community-centred technology from Melbourne, Australia.",
  imageUrl: "/images/og-default.png",
  openGraph: { type: "website" },
  canonicalUrl: "/",
};

const projects = (await getCollection("projects"))
  .map((project) => ({
    url: project.data.canonicalUrl,
    frontmatter: project.data,
  }))
  .filter((project) => project.frontmatter.featured !== false)
  .sort(compareProjectsByPeriod);

const articles = (await getCollection("articles")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("en-AU", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  }).format(new Date(`${date}T00:00:00`));

const articleItems = [
  ...articles.map((article) => ({
    title: article.data.title,
    description: article.data.description,
    href: article.data.canonicalUrl,
    date: article.data.date,
    meta: formatDate(article.data.date),
    detail: getReadingTime(article.body || "").text,
  })),
  ...editorialUpdates.map((update) => ({
    title: update.title,
    description: update.description,
    href: update.canonicalUrl,
    date: update.date,
    meta: formatDate(update.date),
    detail: update.category,
  })),
]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 6)
  .map(({ date: _date, ...item }) => item);

const talkItems = [
  {
    title: "Building a business in an hour... with no code!",
    description:
      "A practical walkthrough of using no-code tools to build a digital-facing business quickly.",
    href: "/assets/slides/no-code-w-notes.pdf",
    meta: "18 AUG 2022",
    detail: "ENTREPRENEURSHIP",
    external: true,
  },
  {
    title: "Concept to Production",
    description:
      "The five steps I use to take startup ideas from a rough concept to a product people can use.",
    href: "https://www.youtube.com/watch?v=_SZP7QmIIfE",
    meta: "03 MAY 2022",
    detail: "ENTREPRENEURSHIP",
    external: true,
  },
  {
    title: "SwinLead Leadership Workshop",
    description:
      "An honest discussion about the experiences, challenges, and successes of leading student communities.",
    href: "https://www.youtube.com/watch?v=7_aJAvfGNsY",
    meta: "13 APR 2022",
    detail: "LEADERSHIP",
    external: true,
  },
];
---

<BaseLayout {...SEO}>
  <NavBar />

  <main id="main-content">
    <section class="site-container hero-shell" aria-labelledby="hero-title">
      <div class="hero">
        <div class="hero__copy" data-motion-intro-group>
          <p class="hero__eyebrow" data-motion-intro-item>// DAN FERG — BUILDER / STRATEGIST / OPTIMIST</p>
          <h1 id="hero-title" data-motion-intro-item>Technology for <em>problems that actually matter.</em></h1>
          <p class="hero__lede" data-motion-intro-item>
            I help founders and mission-led teams turn hard product, operational,
            and community problems into useful software, traction, and a clearer
            route to market.
          </p>
          <p class="hero__offer" data-motion-intro-item>
            <span>OPEN TO</span>
            Consulting · Product, traction &amp; GTM advisory · Speaking
          </p>
          <div class="hero__actions" data-motion-intro-item>
            <a class="button button--primary" href="#projects" data-motion-interactive>Explore my work <span aria-hidden="true" data-motion-arrow data-motion-axis="y">↓</span></a>
            <a class="button" href="/consulting" data-motion-interactive>Discuss a project <span aria-hidden="true" data-motion-arrow>→</span></a>
          </div>
        </div>

        <aside class="hero__signal" aria-label="Portrait of Dan Ferg" data-motion-intro data-motion-scale data-motion-delay="0.16">
          <HeroPortrait />
        </aside>
      </div>
    </section>

    <ImpactStats />

    <section id="projects" class="site-container page-section" aria-labelledby="projects-title">
      <SectionHeading
        headingId="projects-title"
        eyebrow="01 // SELECTED PROJECTS"
        title="Selected work with a job to do."
        description="Current ventures, live client platforms, and formative builds that show how I turn difficult problems into useful systems."
        actionHref="/projects"
        actionLabel="Open project archive"
      />
      <ProjectGrid projects={projects} />
    </section>

    <hr class="site-container ascii-rule" />

    <section id="articles" class="site-container page-section" aria-labelledby="articles-title">
      <SectionHeading
        headingId="articles-title"
        eyebrow="02 // ARTICLES"
        title="Notes from making things."
        description="Writing about entrepreneurship, burnout, software decisions, and the lessons that only turn up once you start."
        actionHref="/articles"
        actionLabel="Read every article"
      />
      <ContentList items={articleItems} orderedLabel="Latest articles" />
    </section>

    <hr class="site-container ascii-rule" />

    <section id="work" class="site-container page-section" aria-labelledby="work-title">
      <SectionHeading
        headingId="work-title"
        eyebrow="03 // WORK HISTORY"
        title="A career spent making useful things."
        description="From public-interest data platforms to startups and disaster-response services, the through-line is simple: use technology to make hard, human problems easier to act on."
        actionHref="https://www.linkedin.com/in/danferg"
        actionLabel="View the full LinkedIn profile"
      />
      <WorkHistory />
      {/* <FavouriteStack /> */}
    </section>

    <section id="talks" class="talks" aria-labelledby="talks-title">
      <div class="site-container page-section">
        <SectionHeading
          headingId="talks-title"
          eyebrow="04 // TALKS"
          title="Ideas, spoken aloud."
          description="Talks and workshops about building startups, working without code, and developing leaders."
        />
        <ContentList items={talkItems} orderedLabel="Talks and workshops" />
      </div>
    </section>

    <section class="site-container contact-panel" aria-labelledby="contact-title" data-motion-reveal>
      <p>// CONSULTING / ADVISORY / SPEAKING</p>
      <h2 id="contact-title">Bring me the useful problem that refuses to fit in a neat box.</h2>
      <p class="contact-panel__lede">
        Consulting when something needs building, advisory across product, traction
        and GTM, and practical speaking for teams working through change.
      </p>
      <a href="mailto:gday@danferg.com?subject=Consulting%2C%20advisory%20or%20speaking%20enquiry" data-motion-interactive>gday@danferg.com <span aria-hidden="true" data-motion-arrow>↗</span></a>
    </section>
  </main>
</BaseLayout>

<style>
  .hero-shell {
    margin-top: clamp(2rem, 4vw, 3.5rem);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.28fr) minmax(19rem, 0.72fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    padding-block: clamp(2rem, 5vw, 4.5rem);
  }

  .hero__eyebrow {
    margin: 0 0 1.15rem;
    color: var(--ink-muted);
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  h1 {
    max-width: 14ch;
    margin: 0;
    font-size: clamp(2.7rem, 6vw, 5.25rem);
    line-height: 0.92;
    letter-spacing: -0.07em;
  }

  h1 em {
    color: var(--signal);
    font-style: normal;
  }

  .hero__lede {
    max-width: 47rem;
    margin: 1.5rem 0 0;
    color: var(--ink-soft);
    font-size: clamp(0.88rem, 1.6vw, 1rem);
    line-height: 1.65;
  }

  .hero__offer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.75rem;
    align-items: center;
    max-width: 47rem;
    margin: 1rem 0 0;
    color: var(--ink-soft);
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 0.025em;
    line-height: 1.5;
  }

  .hero__offer span {
    padding: 0.22rem 0.4rem;
    color: var(--inverse-ink);
    background: var(--signal-fill);
    font-size: 0.57rem;
    letter-spacing: 0.08em;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .button {
    display: inline-flex;
    gap: 1.5rem;
    align-items: center;
    justify-content: space-between;
    min-width: 11.5rem;
    padding: 0.68rem 0.8rem;
    border: 1px solid var(--ink);
    color: var(--ink);
    font-size: 0.68rem;
    font-weight: 750;
    text-decoration: none;
  }

  .button:is(:hover, :focus-visible),
  .button--primary {
    color: var(--inverse-ink);
    background: var(--signal-deep);
  }

  .button--primary:is(:hover, :focus-visible) {
    border-color: var(--signal);
    background: var(--signal-fill);
  }

  .hero__signal {
    align-self: stretch;
    min-height: 0;
  }

  .hero__signal :global(.hero-portrait) {
    position: relative;
    height: 100%;
    min-height: 30rem;
    margin: 0;
    overflow: hidden;
    border-top: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
    background: var(--signal-soft);
  }

  .hero__signal :global(.hero-portrait__image) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 50%;
    filter: url("#hero-portrait-light-palette");
  }

  :global(:root[data-theme="dark"]) .hero__signal :global(.hero-portrait__image) {
    filter: none;
  }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme])) .hero__signal :global(.hero-portrait__image) {
      filter: none;
    }
  }

  .talks {
    color: var(--inverse-ink);
    background: var(--signal-deep);
  }

  .talks :global(.section-heading__eyebrow) {
    color: var(--signal-bright);
  }

  .talks :global(.section-heading__aside p),
  .talks :global(.content-list__copy > span),
  .talks :global(.content-list__index),
  .talks :global(.content-list__meta) {
    color: var(--inverse-muted);
  }

  .talks :global(.content-list),
  .talks :global(.content-list li) {
    border-color: rgb(237 233 255 / 32%);
  }

  .talks :global(.content-list a),
  .talks :global(.section-heading__aside a) {
    color: var(--inverse-ink);
  }

  .contact-panel {
    margin-block: clamp(3.5rem, 7vw, 6rem);
    padding: clamp(1.75rem, 4vw, 3.5rem);
    color: var(--inverse-ink);
    background: var(--signal-fill);
  }

  .contact-panel p {
    margin: 0 0 1.25rem;
    font-size: 0.63rem;
    font-weight: 750;
    letter-spacing: 0.08em;
  }

  .contact-panel h2 {
    max-width: 18ch;
    margin: 0;
    font-size: clamp(1.75rem, 4.5vw, 3.75rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .contact-panel .contact-panel__lede {
    max-width: 62ch;
    margin: 1.2rem 0 0;
    color: var(--inverse-ink);
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.65;
  }

  .contact-panel a {
    display: inline-block;
    margin-top: 1.5rem;
    color: inherit;
    font-weight: 750;
    text-underline-offset: 0.25em;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero__signal {
      max-width: 32rem;
      margin-top: 0;
    }

    .hero__signal :global(.hero-portrait) {
      aspect-ratio: 4 / 3;
      height: auto;
      min-height: 0;
    }
  }

  @media (max-width: 620px) {
    .hero {
      padding-block: 1.25rem;
    }

    h1 {
      font-size: clamp(2.65rem, 14vw, 4.4rem);
    }

    .button {
      width: 100%;
    }

    .contact-panel {
      width: 100%;
    }
  }
</style>
