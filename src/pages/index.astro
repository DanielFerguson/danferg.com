---
import type Article from "types/Article";
import type Project from "types/Project";
import type SEO from "types/SEO";

import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import ContentList from "../components/ContentList.astro";

type MarkdownModule<T> = {
  frontmatter: T;
  url: string;
};

const SEO: SEO = {
  title: "Social entrepreneur and software builder | Dan Ferg",
  description:
    "Dan Ferg builds practical software, social-impact ventures, and community-centred products from Melbourne, Australia.",
  imageUrl: "/assets/snow.jpg",
  openGraph: { type: "website" },
  canonicalUrl: "/",
};

const projects = Object.values(
  import.meta.glob<MarkdownModule<Project>>("./projects/*.md", { eager: true })
).sort(
  (a, b) =>
    Number(Boolean(b.frontmatter.highlight)) -
      Number(Boolean(a.frontmatter.highlight)) ||
    a.frontmatter.title.localeCompare(b.frontmatter.title)
);

const articles = Object.values(
  import.meta.glob<MarkdownModule<Article>>("./articles/*.md", { eager: true })
).sort(
  (a, b) =>
    new Date(b.frontmatter.date).getTime() -
    new Date(a.frontmatter.date).getTime()
);

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("en-AU", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  }).format(new Date(`${date}T00:00:00`));

const articleItems = articles.slice(0, 6).map((article) => ({
  title: article.frontmatter.title,
  description: article.frontmatter.description,
  href: article.url,
  meta: formatDate(article.frontmatter.date),
  detail: article.frontmatter.minutesRead,
}));

const talkItems = [
  {
    title: "Building a business in an hour... with no code!",
    description:
      "A practical walkthrough of using no-code tools to build a digital-facing business quickly.",
    href: "/assets/slides/no-code-w-notes.pdf",
    meta: "18 AUG 2022",
    detail: "ENTREPRENEURSHIP",
    external: true,
  },
  {
    title: "Concept to Production",
    description:
      "The five steps I use to take startup ideas from a rough concept to a product people can use.",
    href: "https://www.youtube.com/watch?v=_SZP7QmIIfE",
    meta: "03 MAY 2022",
    detail: "ENTREPRENEURSHIP",
    external: true,
  },
  {
    title: "SwinLead Leadership Workshop",
    description:
      "An honest discussion about the experiences, challenges, and successes of leading student communities.",
    href: "https://www.youtube.com/watch?v=7_aJAvfGNsY",
    meta: "13 APR 2022",
    detail: "LEADERSHIP",
    external: true,
  },
];
---

<BaseLayout {...SEO}>
  <NavBar />

  <main>
    <section class="site-container hero-shell" aria-labelledby="hero-title">
      <div class="hero">
        <div class="hero__copy">
          <p class="hero__eyebrow">// DAN FERG — BUILDER / STRATEGIST / OPTIMIST</p>
          <h1 id="hero-title">Technology for <em>problems that actually matter.</em></h1>
          <p class="hero__lede">
            I’m a social entrepreneur and software builder working where technology,
            community, and practical problem-solving meet.
          </p>
          <div class="hero__actions">
            <a class="button button--primary" href="#projects">Explore my work <span aria-hidden="true">↓</span></a>
            <a class="button" href="mailto:gday@danferg.com">Start a conversation <span aria-hidden="true">↗</span></a>
          </div>
        </div>

        <aside class="hero__signal" aria-label="Current work">
          <p class="hero__signal-label"><span aria-hidden="true"></span> CURRENTLY_BUILDING</p>
          <a class="hero__signal-title" href="/projects/communitilabs">
            <strong>Communiti Labs</strong>
            <span aria-hidden="true">↗</span>
          </a>
          <dl>
            <div>
              <dt>THESIS</dt>
              <dd>People should be able to see that their voice mattered.</dd>
            </div>
            <div>
              <dt>WORK</dt>
              <dd>Product / strategy / software</dd>
            </div>
            <div>
              <dt>BASE</dt>
              <dd>Melbourne / Australia</dd>
            </div>
          </dl>
        </aside>
      </div>

      <dl class="hero__facts">
        <div><dt>01 / APPROACH</dt><dd>Start with the human problem.</dd></div>
        <div><dt>02 / MEDIUM</dt><dd>Products, systems, and stories.</dd></div>
        <div><dt>03 / PRINCIPLE</dt><dd>Make the complex feel obvious.</dd></div>
      </dl>
    </section>

    <hr class="site-container ascii-rule" />

    <section id="projects" class="site-container page-section" aria-labelledby="projects-title">
      <SectionHeading
        headingId="projects-title"
        eyebrow="01 // SELECTED PROJECTS"
        title="Experiments with a job to do."
        description="Products and ventures built around practical problems—from community response and leadership to productivity and startup infrastructure."
        actionHref="/projects"
        actionLabel="Open project archive"
      />
      <ProjectGrid projects={projects} />
    </section>

    <hr class="site-container ascii-rule" />

    <section id="articles" class="site-container page-section" aria-labelledby="articles-title">
      <SectionHeading
        headingId="articles-title"
        eyebrow="02 // ARTICLES"
        title="Notes from making things."
        description="Writing about entrepreneurship, burnout, software decisions, and the lessons that only turn up once you start."
        actionHref="/articles"
        actionLabel="Read every article"
      />
      <ContentList items={articleItems} orderedLabel="Latest articles" />
    </section>

    <section id="talks" class="talks" aria-labelledby="talks-title">
      <div class="site-container page-section">
        <SectionHeading
          headingId="talks-title"
          eyebrow="03 // TALKS"
          title="Ideas, spoken aloud."
          description="Talks and workshops about building startups, working without code, and developing leaders."
        />
        <ContentList items={talkItems} orderedLabel="Talks and workshops" />
      </div>
    </section>

    <section class="site-container contact-panel" aria-labelledby="contact-title">
      <p>// HAVE A HARD, USEFUL PROBLEM?</p>
      <h2 id="contact-title">Let’s make something that earns its place in the world.</h2>
      <a href="mailto:gday@danferg.com">gday@danferg.com <span aria-hidden="true">↗</span></a>
    </section>
  </main>
</BaseLayout>

<style>
  .hero-shell {
    margin-top: clamp(2rem, 4vw, 3.5rem);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.28fr) minmax(19rem, 0.72fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    padding-block: clamp(2rem, 5vw, 4.5rem);
  }

  .hero__eyebrow {
    margin: 0 0 1.15rem;
    color: var(--ink-muted);
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  h1 {
    max-width: 14ch;
    margin: 0;
    font-size: clamp(2.7rem, 6vw, 5.25rem);
    line-height: 0.92;
    letter-spacing: -0.07em;
  }

  h1 em {
    color: var(--signal);
    font-style: normal;
  }

  .hero__lede {
    max-width: 47rem;
    margin: 1.5rem 0 0;
    color: var(--ink-soft);
    font-size: clamp(0.88rem, 1.6vw, 1rem);
    line-height: 1.65;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .button {
    display: inline-flex;
    gap: 1.5rem;
    align-items: center;
    justify-content: space-between;
    min-width: 11.5rem;
    padding: 0.68rem 0.8rem;
    border: 1px solid var(--ink);
    color: var(--ink);
    font-size: 0.68rem;
    font-weight: 750;
    text-decoration: none;
  }

  .button:hover,
  .button--primary {
    color: var(--paper);
    background: var(--signal-deep);
  }

  .button--primary:hover {
    border-color: var(--signal);
    background: var(--signal);
  }

  .hero__signal {
    align-self: start;
    margin-top: 2.1rem;
    padding-bottom: 0.15rem;
  }

  .hero__signal-label {
    display: flex;
    gap: 0.55rem;
    align-items: center;
    margin: 0 0 0.75rem;
    color: var(--signal);
    font-size: 0.61rem;
    font-weight: 750;
    letter-spacing: 0.07em;
  }

  .hero__signal-label span {
    width: 0.45rem;
    height: 0.45rem;
    background: var(--signal);
    animation: status-pulse 2.4s steps(2, end) infinite;
  }

  .hero__signal-title {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.95rem;
    border-top: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
    color: var(--ink);
    text-decoration: none;
  }

  .hero__signal-title strong {
    font-size: clamp(1.35rem, 2.4vw, 2rem);
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .hero__signal-title:hover {
    color: var(--signal);
  }

  .hero__signal dl {
    margin: 0;
  }

  .hero__signal dl div {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 1rem;
    padding-block: 0.75rem;
    border-bottom: 1px dotted var(--line-strong);
  }

  .hero__signal dt {
    color: var(--ink-muted);
    font-size: 0.6rem;
    font-weight: 750;
    letter-spacing: 0.06em;
  }

  .hero__signal dd {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.72rem;
    line-height: 1.5;
  }

  @keyframes status-pulse {
    50% {
      opacity: 0.25;
    }
  }

  .hero__facts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin: 0 0 clamp(2rem, 5vw, 4.5rem);
    padding: 0.85rem 1.1rem;
    border-top: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
  }

  .hero__facts div {
    padding-right: 1.1rem;
  }

  .hero__facts div + div {
    padding-left: 1.1rem;
    border-left: 1px dotted var(--line-strong);
  }

  .hero__facts dt {
    color: var(--signal);
    font-size: 0.61rem;
    font-weight: 750;
    letter-spacing: 0.06em;
  }

  .hero__facts dd {
    margin: 0.42rem 0 0;
    color: var(--ink-soft);
    font-size: 0.72rem;
    line-height: 1.45;
  }

  .talks {
    color: var(--paper);
    background: var(--signal-deep);
  }

  .talks :global(.section-heading__aside p),
  .talks :global(.content-list__copy > span),
  .talks :global(.content-list__index),
  .talks :global(.content-list__meta) {
    color: var(--paper-muted);
  }

  .talks :global(.content-list),
  .talks :global(.content-list li) {
    border-color: rgb(237 233 255 / 32%);
  }

  .talks :global(.content-list a),
  .talks :global(.section-heading__aside a) {
    color: var(--paper);
  }

  .contact-panel {
    margin-block: clamp(3.5rem, 7vw, 6rem);
    padding: clamp(1.75rem, 4vw, 3.5rem);
    color: var(--paper);
    background: var(--signal);
  }

  .contact-panel p {
    margin: 0 0 1.25rem;
    font-size: 0.63rem;
    font-weight: 750;
    letter-spacing: 0.08em;
  }

  .contact-panel h2 {
    max-width: 18ch;
    margin: 0;
    font-size: clamp(1.75rem, 4.5vw, 3.75rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .contact-panel a {
    display: inline-block;
    margin-top: 1.5rem;
    color: inherit;
    font-weight: 750;
    text-underline-offset: 0.25em;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero__signal {
      max-width: 32rem;
      margin-top: 0;
    }
  }

  @media (max-width: 620px) {
    .hero {
      padding-block: 1.25rem;
    }

    h1 {
      font-size: clamp(2.65rem, 14vw, 4.4rem);
    }

    .button {
      width: 100%;
    }

    .hero__facts {
      grid-template-columns: 1fr;
    }

    .hero__facts div {
      padding: 1rem 0;
    }

    .hero__facts div + div {
      padding-left: 0;
      border-top: 1px dotted var(--line-strong);
      border-left: 0;
    }

    .contact-panel {
      width: 100%;
    }
  }
</style>
