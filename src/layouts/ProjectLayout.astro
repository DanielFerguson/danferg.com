---
import type SEO from "types/SEO";
import { getImage, Picture } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import NavBar from "@components/NavBar.astro";
import ConversionEndcap from "@components/ConversionEndcap.astro";
import {
  getProjectExternalUrl,
  getProjectScreenshot,
} from "../utils/project-assets";
import { getNextProject } from "../data/project-journey";
import { createContactMailto } from "../utils/contact-links";

const { frontmatter } = Astro.props;
const projectUrl = getProjectExternalUrl(frontmatter);
const projectLinkLabel = frontmatter.externalLabel || "Visit project";
const projectScreenshot = getProjectScreenshot(frontmatter.imageKey);
const projectSocialImage = await getImage({
  src: projectScreenshot,
  width: 1200,
  height: 630,
  fit: "cover",
  format: "webp",
  quality: 80,
});
const screenshotAlt =
  frontmatter.imageAlt || `${frontmatter.title} product interface screenshot`;
const caseStudyLabel =
  frontmatter.caseStudyLabel || "CASE STUDY // DAN FERG’S CONTRIBUTION";
const visualLabel = frontmatter.visualLabel || "OUTPUT / PRODUCT_INTERFACE";
const nextProject = getNextProject(frontmatter.canonicalUrl);
const projectStatus = String(frontmatter.status || "").toLowerCase();
const isExploratory = /concept|prototype|proof of concept|mvp|private-beta/.test(
  projectStatus
);
const isCurrent =
  /active|present|live|development|validation|design partner|pre-release/.test(
    projectStatus
  );
const contactTitle = isExploratory
  ? "Need to test an idea without overbuilding it?"
  : isCurrent
    ? `Interested in ${frontmatter.title}—or the thinking behind it?`
    : "Have a hard product problem to untangle?";
const contactDescription = isExploratory
  ? "I help founders and teams turn promising ideas into evidence, focused product decisions, and credible next steps."
  : isCurrent
    ? "I’m open to thoughtful partnerships and focused consulting or advisory work across product, traction, and go-to-market. Tell me what you’re trying to move forward."
    : "I help founders and teams turn difficult product questions into clear decisions, useful software, and a credible path to traction.";
const contactMailto = createContactMailto({
  subject: `Enquiry after reading the ${frontmatter.title} case study`,
  body: `G'day Dan,\n\nI read your ${frontmatter.title} case study and would like to discuss a related challenge.\n\nA little context:\n`,
});
const endcapActions = [
  {
    meta: "CONSULTING / ADVISORY",
    label: "Start a useful conversation",
    href: contactMailto,
  },
  ...(projectUrl
    ? [
        {
          meta: "PROJECT LINK",
          label: projectLinkLabel,
          href: projectUrl,
          external: true,
        },
      ]
    : []),
  {
    meta: "NEXT CASE STUDY",
    label: nextProject.title,
    href: nextProject.href,
    description: nextProject.description,
  },
];

const SEO: SEO & {
  headline: string;
  articleSection: string;
  publishedDate?: string;
  modifiedDate?: string;
  imageWidth?: number;
  imageHeight?: number;
  imageType?: string;
} = {
  title: `${frontmatter.title} | Dan Ferg`,
  headline: frontmatter.title,
  description: frontmatter.description,
  imageUrl: projectSocialImage.src,
  imageAlt: screenshotAlt,
  imageWidth: 1200,
  imageHeight: 630,
  imageType: "image/webp",
  openGraph: { type: "article" },
  canonicalUrl: frontmatter.canonicalUrl,
  schemaType: "CreativeWork",
  publishedDate: frontmatter.publishedDate || frontmatter.date,
  modifiedDate: frontmatter.modifiedDate || frontmatter.updatedDate,
  articleSection: "Case studies",
  breadcrumbs: [
    { name: "Home", url: "/" },
    { name: "Projects", url: "/projects" },
    { name: frontmatter.title, url: frontmatter.canonicalUrl },
  ],
};
---

<BaseLayout {...SEO}>
  <NavBar />
  <main id="main-content">
    <header class="site-container project-header" data-motion-intro-group>
      <p class="project-header__path" data-motion-intro-item><a href="/">HOME</a> / <a href="/projects">PROJECTS</a> / CASE_STUDY</p>
      <div class="project-header__grid" data-motion-intro-item>
        <div>
          <p class="project-header__type">{caseStudyLabel}</p>
          <h1>{frontmatter.title}</h1>
        </div>
        <div class="project-header__aside">
          <p>{frontmatter.description}</p>
          {projectUrl && <a href={projectUrl} target="_blank" rel="noopener noreferrer" data-motion-interactive>{projectLinkLabel} <span aria-hidden="true" data-motion-arrow>↗</span></a>}
        </div>
      </div>

      <dl class="project-meta" data-motion-intro-item>
        {frontmatter.period && <div><dt>PERIOD</dt><dd>{frontmatter.period}</dd></div>}
        {frontmatter.status && <div><dt>STATUS</dt><dd>{frontmatter.status}</dd></div>}
        {frontmatter.role && <div><dt>ROLE</dt><dd>{frontmatter.role}</dd></div>}
        {frontmatter.tags?.length > 0 && <div><dt>DISCIPLINES</dt><dd>{frontmatter.tags.join(" / ")}</dd></div>}
      </dl>
    </header>

    <div class="site-container project-visual" data-motion-reveal data-motion-scale>
      <div class="project-visual__bar"><span>{visualLabel}</span><span>FIG. 01</span></div>
      <Picture
        src={projectScreenshot}
        formats={["avif", "webp"]}
        fallbackFormat="webp"
        alt={screenshotAlt}
        widths={[640, 960, 1280]}
        sizes="(min-width: 1280px) 1216px, calc(100vw - 40px)"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </div>

    <article class="prose-shell" data-motion-reveal>
      <slot />
    </article>

    <ConversionEndcap
      headingId="project-next-step"
      eyebrow="// CONTINUE FROM HERE"
      title={contactTitle}
      description={contactDescription}
      actions={endcapActions}
    />
  </main>
</BaseLayout>

<style>
  .project-header {
    padding-block: clamp(2.5rem, 5vw, 4.75rem) clamp(2.25rem, 4vw, 3.75rem);
  }

  .project-header__path,
  .project-header__type,
  .project-visual__bar {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
  }

  .project-header__path {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .project-header__path a {
    color: var(--ink);
    text-underline-offset: 0.2em;
  }

  .project-header__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 0.65fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: end;
  }

  .project-header__type {
    margin-bottom: 0.85rem;
    color: var(--signal);
    font-weight: 750;
  }

  h1 {
    max-width: 12ch;
    margin: 0;
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    line-height: 0.93;
    letter-spacing: -0.075em;
  }

  .project-header__aside p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.82rem;
    line-height: 1.65;
  }

  .project-header__aside a {
    display: inline-block;
    margin-top: 1rem;
    color: var(--ink);
    font-weight: 750;
    text-underline-offset: 0.22em;
  }

  .project-header__aside a:is(:hover, :focus-visible) {
    color: var(--signal);
  }

  .project-meta {
    display: grid;
    grid-template-columns: 0.75fr 0.9fr 1.15fr 1.6fr;
    margin: clamp(2.25rem, 4vw, 3.5rem) 0 0;
    padding: 1rem 0 0;
    border-top: 1px solid var(--line-strong);
  }

  .project-meta div {
    padding-right: 1rem;
  }

  .project-meta div + div {
    padding-left: 1rem;
    border-left: 1px dotted var(--line-strong);
  }

  .project-meta dt {
    color: var(--signal);
    font-size: 0.58rem;
    font-weight: 750;
    letter-spacing: 0.06em;
  }

  .project-meta dd {
    margin: 0.4rem 0 0;
    color: var(--ink-soft);
    font-size: 0.68rem;
    line-height: 1.5;
  }

  .project-visual {
    border: 1px solid var(--line-strong);
    background: var(--paper-raised);
  }

  .project-visual__bar {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--line-strong);
  }

  .project-visual :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 720px) {
    .project-header__grid {
      grid-template-columns: 1fr;
    }

    .project-meta {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .project-meta div {
      padding: 0.85rem 0;
    }

    .project-meta div + div {
      padding-left: 0;
      border-left: 0;
    }

    .project-meta div:nth-child(even) {
      padding-left: 1rem;
      border-left: 1px dotted var(--line-strong);
    }

    .project-meta div:nth-child(n + 3) {
      border-top: 1px dotted var(--line-strong);
    }
  }
</style>
