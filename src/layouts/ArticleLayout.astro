---
import type SEO from "types/SEO";
import BaseLayout from "./BaseLayout.astro";
import NavBar from "@components/NavBar.astro";
import EditorialEndcap from "@components/EditorialEndcap.astro";
import RelatedContent from "@components/RelatedContent.astro";

const { frontmatter } = Astro.props;
const isDraft = frontmatter.draft === true;
const formatDate = (date: string) =>
  new Intl.DateTimeFormat("en-AU", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  }).format(new Date(`${date}T00:00:00`));
const modifiedDate = frontmatter.modifiedDate || frontmatter.updatedDate;

const SEO: SEO & {
  headline: string;
  articleSection: string;
  modifiedDate?: string;
  imageWidth?: number;
  imageHeight?: number;
  imageType?: string;
} = {
  title: `${frontmatter.title} | Dan Ferg`,
  headline: frontmatter.title,
  description: frontmatter.description,
  imageUrl: frontmatter.imageUrl,
  imageUrls: frontmatter.imageUrls,
  imageAlt:
    frontmatter.imageAlt || `${frontmatter.title} article cover image`,
  imageWidth: frontmatter.imageWidth,
  imageHeight: frontmatter.imageHeight,
  imageType: frontmatter.imageType,
  openGraph: { type: "article" },
  canonicalUrl: frontmatter.canonicalUrl,
  schemaType: "Article",
  publishedDate: frontmatter.date,
  modifiedDate,
  articleSection: "Articles",
  robots: isDraft ? "noindex,nofollow,noarchive" : undefined,
  breadcrumbs: [
    { name: "Home", url: "/" },
    { name: "Articles", url: "/articles" },
    { name: frontmatter.title, url: frontmatter.canonicalUrl },
  ],
};
---

<BaseLayout {...SEO}>
  <NavBar />
  <main id="main-content">
    <header class="site-container story-header" data-motion-intro-group>
      <p class="story-header__path" data-motion-intro-item><a href="/">HOME</a> / <a href="/articles">ARTICLES</a> / {isDraft ? "DRAFT" : "FILE"}</p>
      <div class="story-header__grid" data-motion-intro-item>
        <div>
          <p class="story-header__type">
            ARTICLE // {isDraft ? "LOCAL DRAFT" : "PUBLISHED"} <time datetime={frontmatter.date}>{formatDate(frontmatter.date).toUpperCase()}</time>
            {modifiedDate && modifiedDate !== frontmatter.date && <> // UPDATED <time datetime={modifiedDate}>{formatDate(modifiedDate).toUpperCase()}</time></>}
          </p>
          <h1>{frontmatter.title}</h1>
        </div>
        <p class="story-header__description">{frontmatter.description}</p>
      </div>
    </header>
    <hr class="site-container ascii-rule" />
    <article class="prose-shell article-prose" data-motion-reveal>
      <slot />
    </article>
    <RelatedContent currentPath={frontmatter.canonicalUrl} kind="articles" />
    <EditorialEndcap sourceTitle={frontmatter.title} />
  </main>
</BaseLayout>

<style>
  .story-header {
    padding-block: clamp(2.5rem, 5vw, 4.75rem) clamp(2.25rem, 4vw, 3.75rem);
  }

  .story-header__path,
  .story-header__type {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
  }

  .story-header__path {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .story-header__path a {
    color: var(--ink);
    text-underline-offset: 0.2em;
  }

  .story-header__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 0.65fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: end;
  }

  .story-header__type {
    margin-bottom: 0.85rem;
    color: var(--signal);
    font-weight: 750;
  }

  h1 {
    max-width: 15ch;
    margin: 0;
    font-size: clamp(2.25rem, 5.5vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.07em;
  }

  .story-header__description {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.82rem;
    line-height: 1.65;
  }

  @media (max-width: 720px) {
    .story-header__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { initializeMermaidDiagrams } from "../scripts/mermaid-diagrams";

  void initializeMermaidDiagrams();
</script>
