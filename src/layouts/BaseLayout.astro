---
import type SEO from "types/SEO";

export interface Props extends SEO {}

const {
  title,
  description,
  imageUrl,
  openGraph,
  canonicalUrl,
  schemaType = openGraph.type === "article" ? "Article" : "WebPage",
  publishedDate,
  modifiedDate,
  breadcrumbs = [],
  jsonLd,
} = Astro.props;

const siteUrl = "https://danferg.com";
const absoluteUrl = (url: string) => new URL(url, siteUrl).toString();
const pageUrl = absoluteUrl(canonicalUrl);
const absoluteImageUrl = absoluteUrl(imageUrl);
const personId = `${siteUrl}/#person`;
const websiteId = `${siteUrl}/#website`;
const normalizedJsonLd = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const breadcrumbJsonLd =
  breadcrumbs.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbs.map((item, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: item.name,
          item: absoluteUrl(item.url),
        })),
      }
    : null;
const pageJsonLd = {
  "@context": "https://schema.org",
  "@type": schemaType,
  "@id": `${pageUrl}#page`,
  url: pageUrl,
  name: title,
  headline: title,
  description,
  image: absoluteImageUrl,
  isPartOf: { "@id": websiteId },
  author: { "@id": personId },
  publisher: { "@id": personId },
  inLanguage: "en-AU",
  ...(publishedDate ? { datePublished: publishedDate } : {}),
  ...(modifiedDate || publishedDate
    ? { dateModified: modifiedDate || publishedDate }
    : {}),
};
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": personId,
    name: "Dan Ferg",
    url: siteUrl,
    jobTitle: "Social entrepreneur and software builder",
    description:
      "Dan Ferg builds startups, social impact projects, talks, articles, and digital tools for communities and businesses.",
    sameAs: [
      "https://www.linkedin.com/in/danferg",
      "https://twitter.com/thedannyferg",
      "https://github.com/danielferguson",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": websiteId,
    url: siteUrl,
    name: "Dan Ferg",
    publisher: { "@id": personId },
    inLanguage: "en-AU",
  },
  pageJsonLd,
  ...(breadcrumbJsonLd ? [breadcrumbJsonLd] : []),
  ...normalizedJsonLd,
];

import "@fontsource/inter/latin-400.css";
import "@fontsource/inter/latin-600.css";
import "@fontsource/inter/latin-700.css";
import "@fontsource/inter/latin-800.css";
import "../styles/global.css";
import Footer from "../components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Dan Ferg" />
    <link rel="canonical" href={pageUrl} />

    <!-- OpenGraph -->
    <meta property="og:type" content={openGraph.type} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImageUrl} />
    <meta property="og:site_name" content="Dan Ferg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={pageUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={absoluteImageUrl} />
    <meta property="twitter:creator" content="@thedannyferg" />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <script
      is:inline
      src="https://cdn.usefathom.com/script.js"
      data-site="LARYKSES"
      defer
    ></script>
  </head>
  <body>
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  html,
  body {
    font-family:
      "Inter",
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    scroll-behavior: smooth;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family:
      "Inter",
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }
</style>
