---
import type SEO from "types/SEO";

export interface Props extends SEO {}

const {
  title,
  description,
  imageUrl,
  imageAlt = `${title} social preview`,
  robots = "index,follow",
  openGraph,
  canonicalUrl,
  schemaType = openGraph.type === "article" ? "Article" : "WebPage",
  publishedDate,
  modifiedDate,
  breadcrumbs = [],
  jsonLd,
} = Astro.props;

const siteUrl = "https://danferg.com";
const absoluteUrl = (url: string) => new URL(url, siteUrl).toString();
const pageUrl = absoluteUrl(canonicalUrl);
const absoluteImageUrl = absoluteUrl(imageUrl);
const personId = `${siteUrl}/#person`;
const websiteId = `${siteUrl}/#website`;
const normalizedJsonLd = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const breadcrumbJsonLd =
  breadcrumbs.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbs.map((item, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: item.name,
          item: absoluteUrl(item.url),
        })),
      }
    : null;
const pageJsonLd = {
  "@context": "https://schema.org",
  "@type": schemaType,
  "@id": `${pageUrl}#page`,
  url: pageUrl,
  name: title,
  headline: title,
  description,
  image: absoluteImageUrl,
  isPartOf: { "@id": websiteId },
  author: { "@id": personId },
  publisher: { "@id": personId },
  inLanguage: "en-AU",
  ...(publishedDate ? { datePublished: publishedDate } : {}),
  ...(modifiedDate || publishedDate
    ? { dateModified: modifiedDate || publishedDate }
    : {}),
};
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": personId,
    name: "Dan Ferg",
    url: siteUrl,
    jobTitle: "Product consultant, advisor and software builder",
    description:
      "Dan Ferg builds useful software and advises teams on product, traction, go-to-market strategy, and community-centred technology.",
    knowsAbout: [
      "Product strategy",
      "Go-to-market strategy",
      "Software engineering",
      "Civic technology",
      "Social enterprise",
    ],
    sameAs: [
      "https://www.linkedin.com/in/danferg",
      "https://twitter.com/thedannyferg",
      "https://github.com/danielferguson",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": websiteId,
    url: siteUrl,
    name: "Dan Ferg",
    publisher: { "@id": personId },
    inLanguage: "en-AU",
  },
  pageJsonLd,
  ...(breadcrumbJsonLd ? [breadcrumbJsonLd] : []),
  ...normalizedJsonLd,
];

import "@fontsource-variable/geist-mono/wght.css";
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import ThemeHead from "../components/ThemeHead.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeHead />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Dan Ferg" />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={pageUrl} />

    <!-- OpenGraph -->
    <meta property="og:type" content={openGraph.type} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:site_name" content="Dan Ferg" />
    <meta property="og:locale" content="en_AU" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={pageUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <meta name="twitter:creator" content="@thedannyferg" />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <slot />
    <Footer />
  </body>
</html>
