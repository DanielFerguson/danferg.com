---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

export interface CaseStudyImage {
  src: ImageMetadata;
  alt: string;
  caption: string;
  fit?: "cover" | "contain";
}

export interface Props {
  number: string | number;
  label: string;
  layout?: "single" | "two-up" | "three-up";
  items: CaseStudyImage[];
}

const {
  number,
  label,
  layout = "single",
  items,
} = Astro.props;

const figureNumber = String(number).padStart(2, "0");
const accessibleLabel = label.replace(/[_/]+/g, " ").replace(/\s+/g, " ").trim();
const imageSizes = {
  single: "(min-width: 1280px) 1150px, calc(100vw - 42px)",
  "two-up":
    "(min-width: 1280px) 575px, (min-width: 761px) calc((100vw - 43px) / 2), calc(100vw - 26px)",
  "three-up":
    "(min-width: 1280px) 383px, (min-width: 761px) calc((100vw - 44px) / 3), calc(100vw - 26px)",
} satisfies Record<NonNullable<Props["layout"]>, string>;
---

<figure
  class="case-study-figure"
  data-layout={layout}
  aria-label={`${accessibleLabel}, figure ${figureNumber}`}
>
  <figcaption class="case-study-figure__bar">
    <span>{label}</span>
    <span>FIG. {figureNumber}</span>
  </figcaption>

  <div class="case-study-figure__grid">
    {
      items.map((image) => (
        <div class="case-study-figure__panel">
          <div
            class="case-study-figure__media"
            style={`--case-study-image-fit: ${image.fit ?? "contain"}`}
          >
            <Picture
              src={image.src}
              formats={["avif", "webp"]}
              fallbackFormat="webp"
              alt={image.alt}
              widths={[480, 720, 960, 1280]}
              sizes={imageSizes[layout]}
              loading="lazy"
              decoding="async"
            />
          </div>
          <p class="case-study-figure__caption">{image.caption}</p>
        </div>
      ))
    }
  </div>
</figure>

<style>
  .case-study-figure {
    --case-study-breakout-width: min(
      calc(100vw - 2.5rem),
      var(--content-width)
    );
    position: relative;
    left: 50%;
    width: var(--case-study-breakout-width);
    max-width: none;
    margin: clamp(2.75rem, 6vw, 4.75rem) 0;
    overflow: hidden;
    border: 1px solid var(--line-strong);
    background: var(--paper-raised);
    transform: translateX(-50%);
  }

  .case-study-figure__bar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin: 0;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--line-strong);
    color: var(--ink-muted);
    font-size: 0.62rem;
    line-height: 1.4;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .case-study-figure__bar span:last-child {
    flex: 0 0 auto;
  }

  .case-study-figure__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--line-strong);
  }

  .case-study-figure[data-layout="two-up"] .case-study-figure__grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .case-study-figure[data-layout="three-up"] .case-study-figure__grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .case-study-figure__panel {
    display: grid;
    min-width: 0;
    grid-template-rows: auto 1fr;
    align-content: start;
    background: var(--paper-raised);
  }

  .case-study-figure__media {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: color-mix(in srgb, var(--signal) 3%, var(--paper));
  }

  .case-study-figure[data-layout="two-up"] .case-study-figure__media,
  .case-study-figure[data-layout="three-up"] .case-study-figure__media {
    aspect-ratio: 4 / 3;
  }

  .case-study-figure__media :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .case-study-figure__media :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    object-fit: var(--case-study-image-fit);
    object-position: center;
  }

  .case-study-figure__caption {
    margin: 0;
    padding: 0.85rem 1rem 0.95rem;
    border-top: 1px solid var(--line-strong);
    color: var(--ink-soft);
    font-size: 0.68rem;
    line-height: 1.55;
  }

  @media (max-width: 760px) {
    .case-study-figure {
      --case-study-breakout-width: calc(100vw - 1.5rem);
    }

    .case-study-figure[data-layout="two-up"] .case-study-figure__grid,
    .case-study-figure[data-layout="three-up"] .case-study-figure__grid {
      grid-template-columns: 1fr;
    }

    .case-study-figure__media,
    .case-study-figure[data-layout="two-up"] .case-study-figure__media,
    .case-study-figure[data-layout="three-up"] .case-study-figure__media {
      aspect-ratio: 16 / 10;
    }
  }
</style>
