---
import WorkbenchTerminal from "./WorkbenchTerminal.astro";

interface StackItem {
  name: string;
  note?: string;
}

interface StackGroup {
  label: string;
  items: StackItem[];
}

const stackGroups: StackGroup[] = [
  {
    label: "Frameworks",
    items: [
      { name: "Laravel" },
      { name: "Astro" },
      { name: "React" },
      { name: "Next.js" },
    ],
  },
  {
    label: "Languages",
    items: [
      { name: "PHP" },
      { name: "TypeScript" },
      { name: "Rust" },
      { name: "Go" },
      { name: "Python" },
    ],
  },
  {
    label: "Data & geospatial",
    items: [
      { name: "PostgreSQL" },
      { name: "pgvector" },
      { name: "Polars" },
      { name: "PostGIS" },
      { name: "Mapbox" },
    ],
  },
  {
    label: "Cloud & network",
    items: [{ name: "AWS", note: "5× certified" }, { name: "Tailscale" }],
  },
  {
    label: "Product & GTM",
    items: [{ name: "Codex" }, { name: "Attio" }],
  },
];

const toolCount = stackGroups.reduce((total, group) => total + group.items.length, 0);
---

<section class="favourite-stack" aria-labelledby="favourite-stack-title">
  <header class="favourite-stack__intro">
    <p class="favourite-stack__eyebrow">03.1 // FAVOURITE STACK</p>
    <div>
      <h3 id="favourite-stack-title">The tools I reach for.</h3>
      <p>
        A focused shortlist of the frameworks, languages, data systems, and services I
        use to take products from a hard problem to dependable delivery.
      </p>
    </div>
  </header>

  <WorkbenchTerminal
    command="defaults --current"
    meta={`${toolCount} TOOLS / ${stackGroups.length} GROUPS`}
    border="block"
  />

  <dl class="stack-manifest">
    {
      stackGroups.map((group, index) => (
        <div class="stack-manifest__row">
          <dt>
            <span aria-hidden="true">[{String(index + 1).padStart(2, "0")}]</span>
            {group.label}
          </dt>
          <dd>
            <ul aria-label={`${group.label} favourites`}>
              {group.items.map((item) => (
                <li>
                  <span>{item.name}</span>
                  {item.note && <small>{item.note}</small>}
                </li>
              ))}
            </ul>
          </dd>
        </div>
      ))
    }
  </dl>
</section>

<style>
  .favourite-stack {
    margin-top: clamp(2.75rem, 6vw, 5rem);
    border: 1px solid var(--line-strong);
    background: var(--paper-raised);
  }

  .favourite-stack__intro {
    display: grid;
    grid-template-columns: minmax(11rem, 0.48fr) minmax(0, 1fr);
    gap: clamp(1.25rem, 4vw, 4rem);
    align-items: start;
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .favourite-stack__eyebrow {
    margin: 0;
    color: var(--signal);
    font-size: 0.64rem;
    font-weight: 750;
    letter-spacing: 0.09em;
  }

  h3 {
    margin: 0;
    font-size: clamp(1.45rem, 3.4vw, 2.35rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .favourite-stack__intro div > p {
    max-width: 49rem;
    margin: 0.75rem 0 0;
    color: var(--ink-soft);
    font-size: 0.78rem;
    line-height: 1.65;
  }

  .stack-manifest {
    margin: 0;
  }

  .stack-manifest__row {
    display: grid;
    grid-template-columns: minmax(11rem, 0.38fr) minmax(0, 1fr);
    border-bottom: 1px solid var(--line-strong);
  }

  .stack-manifest__row dt {
    display: flex;
    gap: 0.7rem;
    align-items: center;
    padding: 1rem;
    color: var(--ink);
    font-size: 0.69rem;
    font-weight: 750;
    letter-spacing: -0.015em;
  }

  .stack-manifest__row dt span {
    color: var(--signal);
    font-size: 0.61rem;
    letter-spacing: 0.04em;
  }

  .stack-manifest__row dd {
    display: flex;
    align-items: center;
    min-width: 0;
    margin: 0;
    padding: 0.72rem 1rem;
    border-left: 1px dotted var(--line-strong);
    background: color-mix(in srgb, var(--signal) 2.5%, transparent);
  }

  .stack-manifest__row ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .stack-manifest__row li {
    display: inline-flex;
    align-items: center;
    min-height: 1.85rem;
    overflow: hidden;
    border: 1px solid var(--line);
    color: var(--ink-soft);
    background: var(--paper);
    font-size: 0.65rem;
    font-weight: 700;
  }

  .stack-manifest__row li > span {
    padding: 0.42rem 0.55rem;
  }

  .stack-manifest__row small {
    align-self: stretch;
    display: inline-flex;
    align-items: center;
    padding: 0.42rem 0.55rem;
    color: var(--inverse-ink);
    background: var(--signal-fill);
    font-size: 0.56rem;
    font-weight: 750;
    letter-spacing: 0.025em;
  }

  @media (max-width: 680px) {
    .favourite-stack__intro,
    .stack-manifest__row {
      grid-template-columns: 1fr;
    }

    .stack-manifest__row dt {
      padding-bottom: 0.55rem;
    }

    .stack-manifest__row dd {
      padding-top: 0.2rem;
      padding-bottom: 1rem;
      border-left: 0;
      background: transparent;
    }

  }
</style>
