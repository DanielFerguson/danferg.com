---
import ThemeToggle from "./ThemeToggle.astro";
const navigation = [
  { name: "Projects", href: "/projects" },
  { name: "Consulting", href: "/consulting" },
  { name: "Articles", href: "/articles" },
  { name: "Work", href: "/#work" },
  { name: "Talks", href: "/#talks" },
  { name: "Newsletters", href: "/newsletters" },
];

---

<header class="site-header">
  <div class="signal-bar">
    <div class="site-container signal-bar__inner">
      <p><span aria-hidden="true">■</span> Melbourne, Australia</p>
      <a href="/consulting" data-motion-interactive>Consulting / advisory / speaking <span aria-hidden="true" data-motion-arrow>→</span></a>
    </div>
  </div>

  <div class="site-container nav-shell">
    <a class="wordmark" href="/" aria-label="Dan Ferg, home">
      <span aria-hidden="true">D/F</span>
    </a>

    <nav aria-label="Main navigation">
      <ul>
        {
          navigation.map((item) => (
            <li><a href={item.href} data-astro-prefetch="hover">{item.name}</a></li>
          ))
        }
      </ul>
    </nav>

    <div class="nav-actions">
      <ThemeToggle />
      <a class="nav-contact" href="/consulting" data-motion-interactive>Work together <span aria-hidden="true" data-motion-arrow>→</span></a>
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--line);
  }

  .signal-bar {
    color: var(--inverse-ink);
    background: var(--signal-deep);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
  }

  .signal-bar__inner,
  .nav-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-actions {
    display: flex;
    gap: 0.65rem;
    align-items: center;
  }

  .signal-bar__inner {
    min-height: 1.9rem;
    gap: 1rem;
  }

  .signal-bar p {
    margin: 0;
  }

  .signal-bar p span {
    margin-right: 0.45rem;
    color: var(--signal-bright);
    font-size: 0.52rem;
  }

  .signal-bar a {
    color: inherit;
    text-decoration-color: var(--signal);
    text-underline-offset: 0.2em;
  }

  .nav-shell {
    min-height: 4.25rem;
    gap: 1.15rem;
  }

  .wordmark {
    display: grid;
    width: 2.3rem;
    height: 2.3rem;
    place-items: center;
    flex: 0 0 auto;
    color: var(--inverse-ink);
    background: var(--signal-deep);
    font-weight: 800;
    font-size: 0.7rem;
    letter-spacing: -0.08em;
    text-decoration: none;
    transform: rotate(-3deg);
  }

  nav ul {
    display: flex;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  nav li {
    display: flex;
    align-items: center;
  }

  nav li + li::before {
    margin: 0 0.72rem;
    color: var(--line-strong);
    content: "|";
  }

  nav a,
  .nav-contact {
    color: var(--ink-soft);
    font-size: 0.72rem;
    font-weight: 650;
    text-decoration: none;
  }

  nav a:is(:hover, :focus-visible),
  .nav-contact:is(:hover, :focus-visible) {
    color: var(--signal);
  }

  .nav-contact {
    padding: 0.58rem 0.72rem;
    color: var(--inverse-ink);
    background: var(--signal-fill);
  }

  .nav-contact:is(:hover, :focus-visible) {
    color: var(--inverse-ink);
    background: var(--signal-fill-hover);
  }

  @media (max-width: 760px) {
    .signal-bar__inner {
      align-items: flex-start;
      padding-block: 0.5rem;
    }

    .signal-bar__inner p {
      display: none;
    }

    .nav-shell {
      min-height: auto;
      flex-wrap: wrap;
      padding-block: 0.75rem;
    }

    .nav-shell nav {
      order: 3;
      width: 100%;
      overflow-x: auto;
      padding-top: 0.7rem;
      border-top: 1px dotted var(--line-strong);
    }

    nav ul {
      width: max-content;
    }

    nav li + li::before {
      margin-inline: 0.52rem;
    }

    nav a {
      display: inline-flex;
      min-height: 2rem;
      align-items: center;
    }

    .nav-contact {
      padding: 0.55rem 0.65rem;
    }
  }
</style>
