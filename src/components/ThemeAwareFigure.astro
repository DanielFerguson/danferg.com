---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

export interface Props {
  light: ImageMetadata;
  dark: ImageMetadata;
  alt: string;
  label: string;
  caption: string;
}

const { light, dark, alt, label, caption } = Astro.props;
---

<figure class="theme-aware-figure">
  <div class="theme-aware-figure__media">
    <div
      class="theme-aware-figure__image theme-aware-figure__image--light"
    >
      <Picture
        src={light}
        formats={["avif", "webp"]}
        fallbackFormat="webp"
        widths={[480, 720, 960, 1152]}
        sizes="(min-width: 1280px) 1150px, calc(100vw - 40px)"
        alt={alt}
        loading="lazy"
        decoding="async"
      />
    </div>
    <div
      class="theme-aware-figure__image theme-aware-figure__image--dark"
    >
      <Picture
        src={dark}
        formats={["avif", "webp"]}
        fallbackFormat="webp"
        widths={[480, 720, 960, 1152]}
        sizes="(min-width: 1280px) 1150px, calc(100vw - 40px)"
        alt={alt}
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>
  <figcaption class="theme-aware-figure__caption">
    <span>{label}</span>
    <span>{caption}</span>
  </figcaption>
</figure>

<style>
  .theme-aware-figure {
    --figure-breakout-width: min(
      calc(100vw - 2.5rem),
      var(--content-width)
    );
    position: relative;
    left: 50%;
    width: var(--figure-breakout-width);
    max-width: none;
    margin: clamp(2.75rem, 6vw, 4.75rem) 0;
    overflow: hidden;
    border: 1px solid var(--line-strong);
    background: var(--paper-raised);
    transform: translateX(-50%);
  }

  .theme-aware-figure__media {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--paper-raised);
  }

  .theme-aware-figure__image {
    position: absolute;
    inset: 0;
  }

  .theme-aware-figure__image--dark {
    display: none;
  }

  :global(:root[data-theme="dark"]) .theme-aware-figure__image--light {
    display: none;
  }

  :global(:root[data-theme="dark"]) .theme-aware-figure__image--dark {
    display: block;
  }

  .theme-aware-figure__image :global(picture),
  .theme-aware-figure__image :global(img) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .theme-aware-figure__image :global(img) {
    border: 0;
    object-fit: cover;
  }

  .theme-aware-figure__caption {
    display: grid;
    grid-template-columns: minmax(12rem, 0.4fr) minmax(0, 1fr);
    gap: 0.75rem 2rem;
    margin: 0;
    padding: 0.85rem 1rem 0.95rem;
    border-top: 1px solid var(--line-strong);
    color: var(--ink-soft);
    font-size: 0.68rem;
    line-height: 1.55;
  }

  .theme-aware-figure__caption span:first-child {
    color: var(--signal);
    font-size: 0.62rem;
    font-weight: 750;
    letter-spacing: 0.06em;
  }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme])) .theme-aware-figure__image--light {
      display: none;
    }

    :global(:root:not([data-theme])) .theme-aware-figure__image--dark {
      display: block;
    }
  }

  @media (max-width: 760px) {
    .theme-aware-figure {
      --figure-breakout-width: calc(100vw - 1.5rem);
    }

    .theme-aware-figure__caption {
      grid-template-columns: 1fr;
    }
  }
</style>
