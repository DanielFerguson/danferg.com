---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-container footer-grid">
    <div>
      <p class="footer-label">// FIND ME ONLINE</p>
      <nav aria-label="Social links">
        <a href="https://github.com/danielferguson" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
        <a href="https://www.linkedin.com/in/danferg" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
      </nav>
    </div>
    <p class="footer-note">Technology is my weapon of choice for affecting change in the world around us.</p>
  </div>
  <div class="site-container footer-base">
    <p>© {year} Dan Ferg</p>
    <p>EOF<span aria-hidden="true">_</span></p>
  </div>
</footer>

<style>
  .site-footer {
    color: var(--paper);
    background: var(--signal-deep);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.7fr);
    gap: 3rem;
    padding-block: clamp(2.75rem, 5vw, 4.5rem);
  }

  .footer-label {
    margin: 0 0 1rem;
    color: var(--signal-bright);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
  }

  nav a {
    color: inherit;
    text-underline-offset: 0.22em;
  }

  nav a:hover {
    color: var(--signal);
  }

  .footer-note {
    max-width: 34rem;
    margin: 0;
    color: var(--paper);
    font-size: 0.82rem;
    line-height: 1.65;
  }

  .footer-base {
    display: flex;
    justify-content: space-between;
    padding-block: 1rem;
    border-top: 1px dotted rgb(247 246 241 / 35%);
    color: var(--paper-muted);
    font-size: 0.65rem;
  }

  .footer-base p {
    margin: 0;
  }

  .footer-base span {
    color: var(--signal-bright);
  }

  @media (max-width: 700px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
