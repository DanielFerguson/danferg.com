---
export interface CaseStudyDataItem {
  value: string;
  title: string;
  detail?: string;
}

export interface Props {
  label: string;
  items: CaseStudyDataItem[];
}

const { label, items } = Astro.props;
const accessibleLabel = label.replace(/[_/]+/g, " ").replace(/\s+/g, " ").trim();
const compactValueStyle =
  "font-size: clamp(1.65rem, 2.8vw, 2.35rem); letter-spacing: -0.06em; overflow-wrap: normal; white-space: nowrap;";
---

<section class="case-study-data-band" aria-label={accessibleLabel}>
  <header class="case-study-data-band__bar">
    <p>{label}</p>
    <span aria-hidden="true">
      {String(items.length).padStart(2, "0")} DATA POINTS
    </span>
  </header>

  <dl class="case-study-data-band__grid">
    {
      items.map((item) => (
        <div class="case-study-data-band__item">
          <dt
            style={item.value.length >= 9 && !item.value.includes(" ")
              ? compactValueStyle
              : undefined}
          >
            {item.value}
          </dt>
          <dd>
            <strong>{item.title}</strong>
            {item.detail && <span>{item.detail}</span>}
          </dd>
        </div>
      ))
    }
  </dl>
</section>

<style>
  .case-study-data-band {
    --case-study-breakout-width: min(
      calc(100vw - 2.5rem),
      var(--content-width)
    );
    position: relative;
    left: 50%;
    width: var(--case-study-breakout-width);
    max-width: none;
    margin: clamp(2.75rem, 6vw, 4.75rem) 0;
    overflow: hidden;
    border: 1px solid var(--line-strong);
    background: var(--paper-raised);
    transform: translateX(-50%);
  }

  .case-study-data-band__bar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--line-strong);
    color: var(--ink-muted);
    font-size: 0.62rem;
    line-height: 1.4;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .case-study-data-band__bar p {
    margin: 0;
  }

  .case-study-data-band__bar span {
    flex: 0 0 auto;
  }

  .case-study-data-band__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 1px;
    margin: 0;
    background: var(--line-strong);
  }

  .case-study-data-band__item {
    display: flex;
    min-width: 0;
    min-height: 10.5rem;
    flex-direction: column;
    padding: clamp(1rem, 2.2vw, 1.4rem);
    background: var(--paper-raised);
  }

  .case-study-data-band__item dt {
    margin: 0;
    color: var(--signal-emphasis);
    font-size: clamp(1.8rem, 3.7vw, 3rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.075em;
    overflow-wrap: anywhere;
  }

  .case-study-data-band__item dd {
    display: flex;
    flex: 1;
    flex-direction: column;
    margin: 0.8rem 0 0;
  }

  .case-study-data-band__item strong {
    color: var(--ink);
    font-size: 0.72rem;
    font-weight: 750;
    line-height: 1.45;
  }

  .case-study-data-band__item dd span {
    display: block;
    margin-top: auto;
    padding-top: 1rem;
    color: var(--ink-soft);
    font-size: 0.64rem;
    line-height: 1.55;
  }

  @media (max-width: 760px) {
    .case-study-data-band {
      --case-study-breakout-width: calc(100vw - 1.5rem);
    }

    .case-study-data-band__item {
      min-height: 9.5rem;
    }

    .case-study-data-band__item dt {
      font-size: clamp(1.8rem, 9vw, 2.65rem);
    }

  }
</style>
