---
interface Role {
  title: string;
  organisation: string;
  period: string;
  datetime: string;
  description: string;
  tags: string[];
}

const roles: Role[] = [
  {
    title: "Chief Executive Officer",
    organisation: "Communiti Labs",
    period: "AUG 2023 — NOW",
    datetime: "2023-08",
    description:
      "Building analysis and engagement tools that help practitioners turn community contributions into evidence, insight, and better decisions.",
    tags: ["PRODUCT", "COMMUNITY", "AI + ANALYSIS"],
  },
  {
    title: "President",
    organisation: "Helping Group",
    period: "FEB 2020 — NOW",
    datetime: "2020-02",
    description:
      "Founded a digital-first charity after the 2020 bushfires, creating practical services that connect people with support before, during, and after disasters.",
    tags: ["SOCIAL IMPACT", "LEADERSHIP", "DISASTER RESPONSE"],
  },
  {
    title: "Consultant",
    organisation: "Chepstowe Consulting",
    period: "AUG 2022 — SEP 2023",
    datetime: "2022-08",
    description:
      "Designed bespoke systems for insurance and wealth-management clients, including a CRM supporting more than $10M in new business.",
    tags: ["CONSULTING", "SYSTEMS", "DELIVERY"],
  },
  {
    title: "Digital Performance Manager / Analyst",
    organisation: "Aon",
    period: "JAN 2023 — JUL 2023",
    datetime: "2023-01",
    description:
      "Progressed from digital analysis into performance management, using data and systems to improve digital operations and decision-making.",
    tags: ["ANALYTICS", "PERFORMANCE", "OPERATIONS"],
  },
  {
    title: "Head of Technology",
    organisation: "Imperial Wealth",
    period: "MAR 2021 — AUG 2022",
    datetime: "2021-03",
    description:
      "Led designers and developers, united four business units behind one client entry point, and built software for international crypto-mining operations.",
    tags: ["TECHNOLOGY", "TEAM LEAD", "PLATFORMS"],
  },
  {
    title: "Full Stack Developer",
    organisation: "CeRDI",
    period: "FEB 2019 — JAN 2021",
    datetime: "2019-02",
    description:
      "Built data pipelines, knowledge portals, and spatial tools for environmental monitoring, regional collaboration, and family-violence response.",
    tags: ["DATA", "FULL STACK", "PUBLIC INTEREST"],
  },
];
---

<div class="work-terminal" aria-hidden="true">
  <span><b>dan@work</b>:~$ history --reverse --impact</span>
  <span class="work-terminal__status">STATUS: STILL_BUILDING <i></i></span>
</div>

<ol class="work-history" aria-label="Career history">
  {
    roles.map((role, index) => {
      const branch = index === 0 ? "┌─" : index === roles.length - 1 ? "└─" : "├─";

      return (
        <li class="work-role">
          <div class="work-role__meta">
            <span class="work-role__branch" aria-hidden="true">
              {branch}[{String(index + 1).padStart(2, "0")}]
            </span>
            <time datetime={role.datetime}>{role.period}</time>
          </div>

          <div class="work-role__body">
            <p class="work-role__command" aria-hidden="true">
              $ open role/{role.organisation.toLowerCase().replaceAll(" ", "-")}
            </p>
            <h3>
              {role.title} <span>@ {role.organisation}</span>
            </h3>
            <p class="work-role__description">{role.description}</p>
            <ul aria-label={`${role.title} areas`}>
              {role.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          </div>
        </li>
      );
    })
  }
</ol>

<style>
  .work-terminal {
    display: flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--line-strong);
    color: var(--inverse-muted);
    background: var(--code-surface);
    font-size: 0.64rem;
    letter-spacing: 0.025em;
  }

  .work-terminal b {
    color: var(--signal-bright);
  }

  .work-terminal__status {
    display: inline-flex;
    align-items: center;
    color: var(--inverse-ink);
    white-space: nowrap;
  }

  .work-terminal__status i {
    width: 0.48rem;
    height: 0.48rem;
    margin-left: 0.55rem;
    background: #55d68b;
    box-shadow: 0 0 0 3px rgb(85 214 139 / 17%);
  }

  .work-history {
    margin: 0;
    padding: 0;
    border-right: 1px solid var(--line-strong);
    border-left: 1px solid var(--line-strong);
    list-style: none;
  }

  .work-role {
    --role-accent: #4f39f6;
    display: grid;
    grid-template-columns: minmax(10rem, 0.34fr) minmax(0, 1fr);
    border-bottom: 1px solid var(--line-strong);
    background:
      linear-gradient(90deg, color-mix(in srgb, var(--role-accent) 7%, transparent), transparent 34%),
      var(--paper);
    transition: background-color 140ms ease;
  }

  .work-role:nth-child(2) { --role-accent: #b52ab8; }
  .work-role:nth-child(3) { --role-accent: #0b806c; }
  .work-role:nth-child(4) { --role-accent: #bd6500; }
  .work-role:nth-child(5) { --role-accent: #b23b64; }
  .work-role:nth-child(6) { --role-accent: #2869bd; }
  .work-role:nth-child(7) { --role-accent: #397c42; }
  .work-role:nth-child(8) { --role-accent: #7952ad; }

  .work-role:hover {
    background:
      linear-gradient(90deg, color-mix(in srgb, var(--role-accent) 14%, transparent), transparent 48%),
      var(--paper-raised);
  }

  .work-role__meta {
    position: relative;
    padding: 1.35rem 1rem;
    border-right: 1px dotted var(--line-strong);
  }

  .work-role__branch {
    display: block;
    color: var(--role-accent);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  time {
    display: block;
    margin-top: 0.75rem;
    color: var(--ink-muted);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.055em;
  }

  .work-role__body {
    padding: 1.3rem clamp(1rem, 3vw, 2rem) 1.45rem;
  }

  .work-role__command {
    margin: 0 0 0.65rem;
    color: var(--role-accent);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.045em;
  }

  h3 {
    margin: 0;
    font-size: clamp(1rem, 2.3vw, 1.45rem);
    line-height: 1.2;
    letter-spacing: -0.035em;
  }

  h3 span {
    color: var(--role-accent);
  }

  .work-role__description {
    max-width: 75ch;
    margin: 0.65rem 0 0;
    color: var(--ink-soft);
    font-size: 0.75rem;
    line-height: 1.65;
  }

  .work-role__body ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.9rem 0 0;
    padding: 0;
    list-style: none;
  }

  .work-role__body li {
    padding: 0.22rem 0.42rem;
    border: 1px solid color-mix(in srgb, var(--role-accent) 48%, transparent);
    color: var(--ink-soft);
    background: color-mix(in srgb, var(--role-accent) 7%, transparent);
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  :global(:root[data-theme="dark"]) .work-role:nth-child(1) { --role-accent: #aa9cff; }
  :global(:root[data-theme="dark"]) .work-role:nth-child(2) { --role-accent: #f18cff; }
  :global(:root[data-theme="dark"]) .work-role:nth-child(3) { --role-accent: #63d4bb; }
  :global(:root[data-theme="dark"]) .work-role:nth-child(4) { --role-accent: #f3a64f; }
  :global(:root[data-theme="dark"]) .work-role:nth-child(5) { --role-accent: #f286aa; }
  :global(:root[data-theme="dark"]) .work-role:nth-child(6) { --role-accent: #79b4ff; }
  :global(:root[data-theme="dark"]) .work-role:nth-child(7) { --role-accent: #7fd68d; }
  :global(:root[data-theme="dark"]) .work-role:nth-child(8) { --role-accent: #c99cff; }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme])) .work-role:nth-child(1) { --role-accent: #aa9cff; }
    :global(:root:not([data-theme])) .work-role:nth-child(2) { --role-accent: #f18cff; }
    :global(:root:not([data-theme])) .work-role:nth-child(3) { --role-accent: #63d4bb; }
    :global(:root:not([data-theme])) .work-role:nth-child(4) { --role-accent: #f3a64f; }
    :global(:root:not([data-theme])) .work-role:nth-child(5) { --role-accent: #f286aa; }
    :global(:root:not([data-theme])) .work-role:nth-child(6) { --role-accent: #79b4ff; }
    :global(:root:not([data-theme])) .work-role:nth-child(7) { --role-accent: #7fd68d; }
    :global(:root:not([data-theme])) .work-role:nth-child(8) { --role-accent: #c99cff; }
  }

  @media (max-width: 680px) {
    .work-terminal {
      align-items: flex-start;
      flex-direction: column;
    }

    .work-role {
      grid-template-columns: 1fr;
    }

    .work-role__meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding-bottom: 0.8rem;
      border-right: 0;
    }

    time {
      margin-top: 0;
      text-align: right;
    }

    .work-role__body {
      padding-top: 0.3rem;
    }
  }
</style>
