---
import WorkbenchTerminal from "./WorkbenchTerminal.astro";

export interface EndcapAction {
  label: string;
  href: string;
  meta: string;
  description?: string;
  external?: boolean;
}

interface Props {
  headingId: string;
  eyebrow: string;
  title: string;
  description: string;
  actions: EndcapAction[];
}

const { headingId, eyebrow, title, description, actions } = Astro.props;
---

<aside class="site-container conversion-endcap" aria-labelledby={headingId}>
  <WorkbenchTerminal
    command={eyebrow}
    meta="READY / WHEN YOU ARE"
    showPrompt={false}
    border="bottom"
  />

  <div class="conversion-endcap__grid">
    <div class="conversion-endcap__copy">
      <h2 id={headingId}>{title}</h2>
      <p>{description}</p>
    </div>

    <nav class="conversion-endcap__actions" aria-label="Next steps">
      {
        actions.map((action, index) => {
          const opensAway = action.external || action.href.startsWith("mailto:");

          return (
            <a
              class:list={["conversion-endcap__action", { "conversion-endcap__action--primary": index === 0 }]}
              href={action.href}
              target={action.external ? "_blank" : undefined}
              rel={action.external ? "noopener noreferrer" : undefined}
            >
              <span class="conversion-endcap__action-copy">
                <small>{action.meta}</small>
                <strong>{action.label}</strong>
                {action.description && <span>{action.description}</span>}
              </span>
              <span class="conversion-endcap__arrow" aria-hidden="true">
                {opensAway ? "↗" : "→"}
              </span>
            </a>
          );
        })
      }
    </nav>
  </div>
</aside>

<style>
  .conversion-endcap {
    margin-block: clamp(1rem, 3vw, 2rem) clamp(3.5rem, 6vw, 5.5rem);
    overflow: hidden;
    border: 1px solid var(--line-strong);
    background: var(--paper-raised);
  }

  .conversion-endcap__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(20rem, 0.95fr);
  }

  .conversion-endcap__copy {
    padding: clamp(1.5rem, 4vw, 3rem);
    background:
      linear-gradient(130deg, var(--signal-soft), transparent 68%),
      var(--paper-raised);
  }

  h2 {
    max-width: 17ch;
    margin: 0;
    font-size: clamp(1.75rem, 4vw, 3.4rem);
    line-height: 1;
    letter-spacing: -0.07em;
  }

  .conversion-endcap__copy p {
    max-width: 55ch;
    margin: 1rem 0 0;
    color: var(--ink-soft);
    font-size: 0.76rem;
    line-height: 1.7;
  }

  .conversion-endcap__actions {
    display: grid;
    align-content: stretch;
    border-left: 1px solid var(--line-strong);
  }

  .conversion-endcap__action {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.25rem;
    align-items: center;
    padding: 1.15rem 1.25rem;
    border-bottom: 1px dotted var(--line-strong);
    color: var(--ink);
    text-decoration: none;
    transition:
      color 140ms ease,
      background-color 140ms ease;
  }

  .conversion-endcap__action:last-child {
    border-bottom: 0;
  }

  .conversion-endcap__action--primary {
    color: var(--inverse-ink);
    background: var(--signal-fill);
  }

  .conversion-endcap__action:hover,
  .conversion-endcap__action:focus-visible {
    color: var(--inverse-ink);
    background: var(--inverse-surface);
  }

  .conversion-endcap__action:focus-visible {
    outline: 3px solid var(--signal-bright);
    outline-offset: -3px;
  }

  .conversion-endcap__action-copy {
    display: grid;
    gap: 0.3rem;
  }

  .conversion-endcap__action small {
    color: var(--signal);
    font-size: 0.56rem;
    font-weight: 750;
    letter-spacing: 0.07em;
  }

  .conversion-endcap__action--primary small,
  .conversion-endcap__action:hover small,
  .conversion-endcap__action:focus-visible small {
    color: var(--signal-bright);
  }

  .conversion-endcap__action strong {
    font-size: 0.83rem;
    line-height: 1.25;
  }

  .conversion-endcap__action-copy > span {
    color: var(--ink-soft);
    font-size: 0.65rem;
    line-height: 1.55;
  }

  .conversion-endcap__action--primary .conversion-endcap__action-copy > span,
  .conversion-endcap__action:hover .conversion-endcap__action-copy > span,
  .conversion-endcap__action:focus-visible .conversion-endcap__action-copy > span {
    color: var(--inverse-muted);
  }

  .conversion-endcap__arrow {
    font-size: 1.1rem;
  }

  @media (max-width: 800px) {
    .conversion-endcap__grid {
      grid-template-columns: 1fr;
    }

    .conversion-endcap__actions {
      border-top: 1px solid var(--line-strong);
      border-left: 0;
    }
  }

  @media (max-width: 520px) {
    .conversion-endcap__action {
      padding-inline: 1rem;
    }
  }
</style>
