<figure
  class="hero-portrait"
  data-hero-portrait
  data-hero-shader-state="fallback"
>
  <svg
    class="hero-portrait__filters"
    width="0"
    height="0"
    aria-hidden="true"
    focusable="false"
  >
    <defs>
      <!-- The source artwork has four flat colours. This matrix maps its dark
           palette exactly to the corresponding light palette for fallbacks. -->
      <filter
        id="hero-portrait-light-palette"
        color-interpolation-filters="sRGB"
      >
        <feColorMatrix
          type="matrix"
          values="
            -1.10921766 0 1.52904725 0 -0.33579077
            -0.41914106 0 0.64575265 0 -0.09475352
            -0.51828901 1 1.03382391 0 -0.05448682
            0 0 0 1 0
          "
        />
      </filter>
    </defs>
  </svg>
  <script is:inline>
    (() => {
      const portrait = document.currentScript?.parentElement;
      const staticMode =
        new URLSearchParams(window.location.search).get("hero") === "static";
      const reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      if (
        portrait instanceof HTMLElement &&
        portrait.matches("[data-hero-portrait]") &&
        !staticMode &&
        !reducedMotion
      ) {
        portrait.dataset.heroShaderState = "loading";
      }
    })();
  </script>
  <img
    class="hero-portrait__image"
    src="/images/dan-dark.png"
    alt="Dan Ferg in conversation at the CivVic and VicHealth Showcase"
    width="2280"
    height="1283"
  />
</figure>

<script>
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  );
  const staticMode =
    new URLSearchParams(window.location.search).get("hero") === "static";
  const disposers = new Set<() => void>();

  const startExperiment = async () => {
    if (staticMode || prefersReducedMotion.matches) return;

    const portraits = Array.from(
      document.querySelectorAll<HTMLElement>("[data-hero-portrait]"),
    ).filter((portrait) =>
      ["fallback", "loading"].includes(
        portrait.dataset.heroShaderState ?? "fallback",
      ),
    );

    if (portraits.length === 0) return;

    portraits.forEach((portrait) => {
      portrait.dataset.heroShaderState = "loading";
    });

    try {
      const { enhanceHeroPortrait } = await import(
        "../scripts/hero-portrait-shader"
      );

      await Promise.all(
        portraits.map(async (portrait) => {
          const dispose = await enhanceHeroPortrait(portrait);
          if (dispose) disposers.add(dispose);
        }),
      );
    } catch {
      portraits.forEach((portrait) => {
        portrait.dataset.heroShaderState = "fallback";
      });
    }
  };

  void startExperiment();

  window.addEventListener(
    "pagehide",
    () => {
      disposers.forEach((dispose) => dispose());
      disposers.clear();
    },
    { once: true },
  );
</script>

<style>
  .hero-portrait__filters {
    position: absolute;
    pointer-events: none;
  }

  .hero-portrait[data-hero-portrait][data-hero-shader-state="loading"],
  .hero-portrait[data-hero-portrait][data-hero-shader-state="ready"] {
    background: rgb(0 12 56);
  }

  .hero-portrait[data-hero-shader-state="loading"]
    :global(.hero-portrait__image),
  .hero-portrait[data-hero-shader-state="ready"]
    :global(.hero-portrait__image) {
    opacity: 0;
  }

  .hero-portrait :global(canvas.hero-portrait__shader) {
    z-index: 2;
    opacity: 0;
    pointer-events: none;
  }

  .hero-portrait[data-hero-shader-state="ready"]
    :global(canvas.hero-portrait__shader) {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-portrait :global(canvas.hero-portrait__shader) {
      display: none;
    }
  }
</style>
